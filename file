
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MaisonCare — Glow Loud, Glow Proud</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  /* ===== RESET & BASE ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream:   #FAF6F0;
    --blush:   #E8C9B8;
    --rose:    #C47A5A;
    --clay:    #9B5E42;
    --bark:    #3D2314;
    --moss:    #7A8C6E;
    --gold:    #C9A96E;
    --white:   #FFFFFF;
    --text:    #2A1A0E;
    --muted:   #7D6558;
    --radius:  12px;
    --shadow:  0 8px 40px rgba(61,35,20,.12);
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    overflow-x: hidden;
    cursor: none;
  }

  /* ===== CUSTOM CURSOR ===== */
  #cursor {
    width: 14px; height: 14px;
    background: var(--rose);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform .12s, background .2s, width .2s, height .2s;
    mix-blend-mode: multiply;
  }
  #cursor.expand { width: 36px; height: 36px; background: var(--blush); }

  /* ===== SCROLLBAR ===== */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: var(--cream); }
  ::-webkit-scrollbar-thumb { background: var(--blush); border-radius: 4px; }

  /* ===== NAV ===== */
  nav {
    position: fixed; top: 0; left: 0; width: 100%; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 22px 48px;
    backdrop-filter: blur(16px);
    background: rgba(250,246,240,.85);
    border-bottom: 1px solid rgba(196,122,90,.12);
    transition: padding .3s;
  }
  nav.scrolled { padding: 14px 48px; }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem; font-weight: 300; letter-spacing: .08em;
    color: var(--bark); text-decoration: none;
  }
  .nav-logo span { color: var(--rose); font-style: italic; }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    font-size: .82rem; font-weight: 500; letter-spacing: .1em;
    text-transform: uppercase; text-decoration: none;
    color: var(--muted); transition: color .25s;
    position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; left: 0; bottom: -4px;
    width: 0; height: 1px; background: var(--rose); transition: width .3s;
  }
  .nav-links a:hover { color: var(--rose); }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta {
    background: var(--rose); color: #fff;
    padding: 10px 22px; border-radius: 40px;
    font-size: .8rem; font-weight: 500; letter-spacing: .1em;
    text-transform: uppercase; text-decoration: none;
    transition: background .25s, transform .2s;
  }
  .nav-cta:hover { background: var(--clay); transform: scale(1.04); }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
  .hamburger span {
    display: block; width: 24px; height: 2px;
    background: var(--bark); border-radius: 2px; transition: .3s;
  }
  .mobile-menu {
    display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
    background: var(--cream); z-index: 99; flex-direction: column;
    align-items: center; justify-content: center; gap: 32px;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem; font-weight: 300; color: var(--bark);
    text-decoration: none; letter-spacing: .06em;
    transition: color .2s;
  }
  .mobile-menu a:hover { color: var(--rose); }
  .close-menu {
    position: absolute; top: 24px; right: 36px;
    font-size: 2rem; color: var(--muted); cursor: pointer;
  }

  /* ===== HERO ===== */
  #hero {
    min-height: 100vh;
    display: grid; grid-template-columns: 1fr 1fr;
    align-items: center; gap: 0;
    padding-top: 80px;
    overflow: hidden;
    position: relative;
  }
  .hero-bg-shape {
    position: absolute; top: -120px; right: -100px;
    width: 680px; height: 680px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, var(--blush) 0%, rgba(232,201,184,.3) 60%, transparent 80%);
    z-index: 0; animation: floatBlob 8s ease-in-out infinite;
  }
  .hero-bg-shape2 {
    position: absolute; bottom: -80px; left: 80px;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,169,110,.2) 0%, transparent 70%);
    z-index: 0; animation: floatBlob 10s ease-in-out 2s infinite reverse;
  }
  @keyframes floatBlob {
    0%,100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-24px) scale(1.03); }
  }
  .hero-text {
    padding: 80px 48px 80px 80px;
    position: relative; z-index: 1;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(196,122,90,.12); border: 1px solid rgba(196,122,90,.25);
    border-radius: 40px; padding: 6px 16px;
    font-size: .75rem; font-weight: 500; letter-spacing: .12em;
    text-transform: uppercase; color: var(--rose);
    margin-bottom: 28px;
    animation: fadeUp .7s ease both;
  }
  .hero-badge::before { content: '✦'; font-size: .65rem; }
  .hero-h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 5vw, 5.2rem);
    font-weight: 300; line-height: 1.08;
    color: var(--bark); letter-spacing: -.01em;
    animation: fadeUp .7s .15s ease both;
  }
  .hero-h1 em { color: var(--rose); font-style: italic; }
  .hero-tagline {
    margin: 20px 0 36px;
    font-size: 1.05rem; color: var(--muted);
    font-weight: 300; letter-spacing: .04em;
    animation: fadeUp .7s .3s ease both;
  }
  .hero-actions {
    display: flex; gap: 16px; flex-wrap: wrap;
    animation: fadeUp .7s .45s ease both;
  }
  .btn-primary {
    background: var(--bark); color: #fff;
    padding: 14px 32px; border-radius: 40px;
    font-size: .85rem; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; text-decoration: none;
    transition: background .25s, transform .2s;
    border: none; cursor: pointer;
  }
  .btn-primary:hover { background: var(--clay); transform: translateY(-2px); }
  .btn-outline {
    background: transparent; color: var(--bark);
    padding: 14px 32px; border-radius: 40px;
    font-size: .85rem; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; text-decoration: none;
    border: 1.5px solid var(--bark);
    transition: all .25s; cursor: pointer;
  }
  .btn-outline:hover { background: var(--bark); color: #fff; transform: translateY(-2px); }
  .hero-stats {
    margin-top: 52px; display: flex; gap: 40px;
    animation: fadeUp .7s .6s ease both;
  }
  .stat-item { display: flex; flex-direction: column; gap: 4px; }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 600; color: var(--bark);
  }
  .stat-label { font-size: .75rem; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }

  .hero-visual {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    padding: 80px 60px 80px 20px;
    animation: fadeIn 1s .2s ease both;
  }
  .hero-img-wrap {
    position: relative; width: 420px; height: 520px;
  }
  .hero-img-card {
    width: 340px; height: 420px;
    border-radius: 200px 200px 160px 160px;
    background: linear-gradient(145deg, var(--blush) 0%, #d9a98a 60%, var(--rose) 100%);
    overflow: hidden; position: relative;
    box-shadow: 0 30px 80px rgba(155,94,66,.25);
  }
  .hero-img-card::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(61,35,20,.18));
  }
  /* decorative flower / blob inside hero card */
  .hero-blob {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 260px; height: 260px;
    background: rgba(255,255,255,.18);
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    animation: morphBlob 7s ease-in-out infinite;
  }
  @keyframes morphBlob {
    0%,100% { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
    33% { border-radius: 40% 60% 45% 55% / 60% 40% 55% 45%; }
    66% { border-radius: 55% 45% 60% 40% / 45% 55% 50% 50%; }
  }
  .hero-emoji {
    position: absolute; font-size: 5rem;
    top: 50%; left: 50%; transform: translate(-50%,-55%);
    filter: drop-shadow(0 8px 24px rgba(0,0,0,.12));
    animation: floatBlob 5s ease-in-out infinite;
    z-index: 2;
  }
  .hero-pill {
    position: absolute; background: white;
    border-radius: 40px; padding: 10px 18px;
    box-shadow: var(--shadow);
    display: flex; align-items: center; gap: 10px;
    font-size: .8rem; font-weight: 500; color: var(--bark);
    white-space: nowrap;
  }
  .hero-pill.p1 { top: 20px; right: -30px; animation: floatBlob 6s 1s ease-in-out infinite; }
  .hero-pill.p2 { bottom: 60px; left: -40px; animation: floatBlob 7s 2s ease-in-out infinite reverse; }
  .hero-pill.p3 { bottom: -10px; right: 0; animation: floatBlob 5s .5s ease-in-out infinite; }
  .pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--moss); flex-shrink: 0; }
  .pill-dot.r { background: var(--rose); }
  .pill-dot.g { background: var(--gold); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }

  /* ===== MARQUEE ===== */
  .marquee-wrap {
    background: var(--bark); padding: 14px 0; overflow: hidden;
  }
  .marquee-track {
    display: flex; gap: 0; animation: marqueeScroll 18s linear infinite;
    white-space: nowrap;
  }
  .marquee-item {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem; font-style: italic; font-weight: 300;
    color: var(--blush); letter-spacing: .06em;
    padding: 0 40px;
    display: flex; align-items: center; gap: 16px;
  }
  .marquee-item::after { content: '✦'; font-style: normal; color: var(--gold); font-size: .65rem; }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ===== SECTIONS COMMON ===== */
  section { padding: 100px 80px; }
  .section-label {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: .72rem; font-weight: 500; letter-spacing: .18em;
    text-transform: uppercase; color: var(--rose);
    margin-bottom: 16px;
  }
  .section-label::before { content: ''; width: 28px; height: 1px; background: var(--rose); }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 300; line-height: 1.18; color: var(--bark);
  }
  .section-title em { color: var(--rose); font-style: italic; }
  .section-sub {
    margin-top: 14px; font-size: .95rem;
    color: var(--muted); max-width: 480px; line-height: 1.7;
  }

  /* ===== ABOUT ===== */
  #about {
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
    align-items: center; background: white;
  }
  .about-visual {
    display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 16px; height: 460px;
  }
  .about-card {
    border-radius: 20px; overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    transition: transform .3s;
  }
  .about-card:hover { transform: scale(1.04); }
  .about-card.c1 { background: linear-gradient(135deg,#f5e0d4,#e8c9b8); grid-row: span 2; border-radius: 100px 20px 20px 20px; }
  .about-card.c2 { background: linear-gradient(135deg,var(--moss),#5e6e52); color: white; border-radius: 20px 100px 20px 20px; font-size: 2.2rem; }
  .about-card.c3 { background: linear-gradient(135deg,var(--gold),#a87f45); color: white; border-radius: 20px 20px 100px 20px; }
  .about-values { margin-top: 36px; display: flex; flex-direction: column; gap: 14px; }
  .about-val {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 16px 20px; border-radius: 12px;
    background: var(--cream); border-left: 3px solid var(--blush);
    transition: border-color .25s, transform .25s;
  }
  .about-val:hover { border-color: var(--rose); transform: translateX(4px); }
  .val-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }
  .val-title { font-size: .88rem; font-weight: 500; color: var(--bark); margin-bottom: 3px; }
  .val-desc { font-size: .82rem; color: var(--muted); line-height: 1.6; }

  /* ===== PRODUCTS ===== */
  #products { background: var(--cream); }
  .products-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 52px; flex-wrap: wrap; gap: 20px;
  }
  .filter-tabs {
    display: flex; gap: 10px; flex-wrap: wrap;
  }
  .filter-tab {
    padding: 8px 20px; border-radius: 40px;
    font-size: .78rem; font-weight: 500; letter-spacing: .08em;
    text-transform: uppercase; border: 1.5px solid rgba(155,94,66,.25);
    background: transparent; color: var(--muted);
    cursor: pointer; transition: all .22s;
  }
  .filter-tab.active, .filter-tab:hover {
    background: var(--rose); color: white; border-color: var(--rose);
  }
  .products-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(270px,1fr));
    gap: 28px;
  }
  .product-card {
    background: white; border-radius: 20px;
    overflow: hidden; box-shadow: 0 2px 16px rgba(61,35,20,.06);
    transition: transform .3s, box-shadow .3s;
    position: relative;
  }
  .product-card:hover { transform: translateY(-6px); box-shadow: var(--shadow); }
  .product-card[data-category] { transition: transform .3s, box-shadow .3s, opacity .3s; }
  .product-card.hidden { display: none; }
  .product-img {
    width: 100%; height: 220px;
    display: flex; align-items: center; justify-content: center;
    font-size: 4.5rem; position: relative; overflow: hidden;
  }
  .product-img::after {
    content: ''; position: absolute; inset: 0;
    background: inherit; filter: blur(40px) opacity(.35);
    z-index: 0;
  }
  .product-img span { position: relative; z-index: 1; }
  .product-badge {
    position: absolute; top: 14px; left: 14px;
    background: var(--rose); color: white;
    font-size: .68rem; font-weight: 500; letter-spacing: .1em;
    text-transform: uppercase; padding: 4px 12px; border-radius: 40px;
    z-index: 2;
  }
  .product-badge.new { background: var(--moss); }
  .product-badge.sale { background: var(--gold); }
  .product-info { padding: 22px; }
  .product-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem; font-weight: 400; color: var(--bark);
    margin-bottom: 6px;
  }
  .product-desc { font-size: .82rem; color: var(--muted); line-height: 1.6; margin-bottom: 16px; }
  .product-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
  .tag {
    padding: 3px 10px; border-radius: 40px;
    background: var(--cream); font-size: .72rem;
    color: var(--muted); border: 1px solid rgba(155,94,66,.15);
  }
  .product-footer {
    display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid var(--cream); padding-top: 14px;
    margin-top: 4px;
  }
  .product-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem; font-weight: 600; color: var(--bark);
  }
  .product-price .old {
    font-size: .9rem; color: var(--muted);
    text-decoration: line-through; margin-left: 6px; font-weight: 300;
  }
  .btn-order {
    background: var(--bark); color: white;
    padding: 9px 18px; border-radius: 40px;
    font-size: .75rem; font-weight: 500; letter-spacing: .06em;
    text-transform: uppercase; border: none; cursor: pointer;
    transition: background .2s, transform .2s;
  }
  .btn-order:hover { background: var(--rose); transform: scale(1.04); }

  /* ===== INGREDIENTS ===== */
  #ingredients { background: var(--bark); color: var(--cream); }
  #ingredients .section-label { color: var(--gold); }
  #ingredients .section-label::before { background: var(--gold); }
  #ingredients .section-title { color: var(--cream); }
  #ingredients .section-sub { color: rgba(250,246,240,.65); }
  .ingredients-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr));
    gap: 20px; margin-top: 52px;
  }
  .ing-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 16px; padding: 28px 22px;
    text-align: center; transition: background .25s, transform .25s;
  }
  .ing-card:hover { background: rgba(255,255,255,.12); transform: translateY(-4px); }
  .ing-icon { font-size: 2.8rem; margin-bottom: 14px; display: block; }
  .ing-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 400; color: var(--blush);
    margin-bottom: 8px;
  }
  .ing-desc { font-size: .78rem; color: rgba(250,246,240,.55); line-height: 1.7; }

  /* ===== HOW TO ORDER ===== */
  #how-to-order { background: white; }
  .steps-grid {
    display: grid; grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
    gap: 32px; margin-top: 52px; position: relative;
  }
  .steps-grid::before {
    content: ''; position: absolute;
    top: 52px; left: 80px; right: 80px; height: 1px;
    background: linear-gradient(to right, transparent, var(--blush), transparent);
  }
  .step-card {
    text-align: center; padding: 36px 24px;
    border-radius: 20px; background: var(--cream);
    position: relative; transition: transform .25s, box-shadow .25s;
  }
  .step-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }
  .step-num {
    width: 44px; height: 44px;
    background: var(--rose); color: white;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600;
    margin: 0 auto 20px; position: relative; z-index: 1;
  }
  .step-icon { font-size: 2.4rem; margin-bottom: 14px; display: block; }
  .step-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 400; color: var(--bark); margin-bottom: 10px; }
  .step-desc { font-size: .83rem; color: var(--muted); line-height: 1.7; }
  .step-cta-wrap { text-align: center; margin-top: 52px; }

  /* ===== ORDER FORM ===== */
  #order { background: var(--cream); }
  .order-inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
  }
  .order-form {
    background: white; border-radius: 24px; padding: 44px;
    box-shadow: var(--shadow);
  }
  .form-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-weight: 400; color: var(--bark); margin-bottom: 8px;
  }
  .form-sub { font-size: .84rem; color: var(--muted); margin-bottom: 32px; line-height: 1.6; }
  .form-group { margin-bottom: 20px; }
  .form-group label {
    display: block; font-size: .78rem; font-weight: 500;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 7px;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%; padding: 12px 16px; border-radius: 10px;
    border: 1.5px solid rgba(155,94,66,.2);
    background: var(--cream); color: var(--text);
    font-family: 'DM Sans', sans-serif; font-size: .9rem;
    outline: none; transition: border-color .25s, box-shadow .25s;
    -webkit-appearance: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--rose);
    box-shadow: 0 0 0 3px rgba(196,122,90,.12);
  }
  .form-group textarea { resize: vertical; min-height: 90px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .btn-submit {
    width: 100%; padding: 15px; border-radius: 40px;
    background: var(--rose); color: white;
    font-family: 'DM Sans', sans-serif; font-size: .88rem;
    font-weight: 500; letter-spacing: .1em; text-transform: uppercase;
    border: none; cursor: pointer; margin-top: 8px;
    transition: background .25s, transform .2s;
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .btn-submit:hover { background: var(--clay); transform: translateY(-2px); }
  .form-success {
    display: none; text-align: center; padding: 36px 20px;
  }
  .form-success .tick { font-size: 3.5rem; margin-bottom: 16px; display: block; }
  .form-success h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; color: var(--bark); margin-bottom: 10px;
  }
  .form-success p { font-size: .9rem; color: var(--muted); line-height: 1.7; }
